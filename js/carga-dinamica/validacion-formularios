document.addEventListener("DOMContentLoaded", () => {
    // 1. Buscamos el formulario y los inputs
    const form = document.getElementById("form-pago");
    const inputs = document.querySelectorAll(".entrada-texto-pago");

    if (!form) {
        console.error("No se encontró el formulario con id='form-pago'");
        return;
    }

    // 2. Función que aplica TU estilo (el de la foto 2) usando reglas HTML5
    const validar = (input) => {
        const mensajeError = input.parentElement.querySelector(".error-text");
        
        // Si el campo está vacío, limpiamos (opcional)
        if (input.value === "") {
            input.classList.remove("input-error");
            if (mensajeError) mensajeError.style.display = "none";
            return;
        }

        // AQUÍ ESTÁ EL ENUNCIADO: checkValidity() es soporte nativo HTML5
        if (!input.checkValidity()) {
            input.classList.add("input-error"); // Tu clase CSS
            if (mensajeError) {
                mensajeError.textContent = input.getAttribute("data-error");
                mensajeError.style.display = "block";
            }
        } else {
            input.classList.remove("input-error");
            if (mensajeError) mensajeError.style.display = "none";
        }
    };

    // 3. EVENTO EN TIEMPO REAL
    inputs.forEach(input => {
        input.addEventListener("input", () => validar(input));
    });

    // 4. EVITAR EL ENVÍO SI HAY ERRORES
    form.addEventListener("submit", (e) => {
        let esValido = true;
        inputs.forEach(input => {
            validar(input);
            if (!input.checkValidity()) esValido = false;
        });
        if (!esValido) e.preventDefault();
    });
});
